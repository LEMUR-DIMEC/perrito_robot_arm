<mujoco model="robot_arm">
  <compiler angle="radian" meshdir="assets" texturedir="assets"/>

  <option integrator="implicitfast"/>

  <default>
    <default class="brazito">
      <joint damping="1" frictionloss="1"/>
      <general biastype="affine" gainprm="1000" biasprm="0 -1000 -100" forcerange="-30 30"/>
      <default class="visual">
        <geom type="mesh" group="2" contype="0" conaffinity="0"/>
      </default>
      <default class="collision">
        <geom type="cylinder" group="3" mass="0" density="0"/>
      </default>
    </default>
  </default>

  <asset>
    <mesh file="base_link.obj"/>
    <mesh file="L1.obj"/>
    <mesh file="L2.obj"/>
    <mesh file="L3.obj"/>
    <mesh file="L4.obj"/>
    <mesh file="L5.obj"/>
    <mesh file="L6.obj"/>
    <mesh file="gripper.obj"/>

    <texture type="2d" name="base_link" file="base_link.png"/>
    <material name="dark" specular="0" shininess="0.5" rgba="0.25 0.25 0.25 1"/>
    <material name="claro" specular="0" shininess="0.5" rgba="0.85 0.85 0.85 1"/>
    <material name="tex_blanco" texture="base_link" specular="0" shininess="0.25"/>
  </asset>

  <worldbody>
    <body name="base_link" childclass="brazito">
      <inertial pos="-0.00334984 -0.00013615 0.0249584" quat="-0.00692194 0.682592 0.00133293 0.730766" mass="0.472475"
        diaginertia="0.000531375 0.000415207 0.000378658"/>
      <geom class="visual" mesh="base_link" material="tex_blanco"/>
      <!-- <geom size="0.0325 0.0255" pos="0 0 0.0255" class="collision"/> -->

      <!-- LINK1 -->
      <body name="link01" pos="0 0 0.0906">
        <inertial pos="2.47e-06 -0.00025198 0.0231717" quat="0.708578 0.705633 0.000281462 -0.000355927" mass="0.673326"
          diaginertia="0.00128328 0.000839362 0.000719308"/>
        <joint name="joint1" axis="0 0 1" range="-2.62 2.62"/>
        <geom class="visual" mesh="L1" material="dark"/>

        <!-- LINK 2 -->
        <body name="link02" pos="-0.0065 0 0.0902">
          <inertial pos="-0.110126 0.00240029 0.00158266" quat="0.00748058 0.707092 -0.0114473 0.70699" mass="1.19132"
            diaginertia="0.0246612 0.0243113 0.00100468"/>
          <joint name="joint2" axis="1 0 0" range="-0.7 4" damping="2"/>
          <geom class="visual" mesh="L2"/>
          <geom size="0.0325 0.051" quat="1 1 0 0" class="collision"/>
          <geom size="0.0225 0.1175" pos="-0.1625 0 0" quat="1 0 1 0" class="collision"/>
          <geom size="0.0325 0.0255" pos="-0.35 0 0" quat="1 1 0 0" class="collision"/>

          <!-- LINK 3 -->
          <body name="link03" pos="-0.03 0.3415 0 ">
            <inertial pos="0.106092 -0.00541815 0.0347638" quat="0.540557 0.443575 0.426319 0.573839" mass="0.839409"
              diaginertia="0.00954365 0.00938711 0.000558432"/>
            <joint name="joint3" axis="1 0 0" range="-2.62 2.62"/>
            <geom class="visual" mesh="L3" material="dark"/>
            <geom size="0.02 0.058" pos="0.128 0 0.055" quat="1 0 1 0" class="collision"/>
            <geom size="0.0325 0.0295" pos="0.2205 0 0.055" quat="0.5 -0.5 0.5 0.5" class="collision"/>

            <!-- LINK 4 -->
            <body name="link04" pos="-0.06 0 0.0238">
              <inertial pos="0.0436668 0.00364738 -0.00170192" quat="0.0390835 0.726445 -0.0526787 0.684087"
                mass="0.564046" diaginertia="0.000981656 0.00094053 0.000302655"/>
              <joint name="joint4" axis="0 0 1" range="-2.62 2.62"/>
              <geom class="visual" mesh="L4"/>
              <geom size="0.0325 0.0335" pos="0.072 0 0" class="collision"/>

              <!-- LINK 5 -->
              <body name="link05" pos="0 -0.024 0.321">
                <inertial pos="0.0312153 0 0.00646316" quat="0.462205 0.535209 0.53785 0.45895" mass="0.389385"
                  diaginertia="0.000558961 0.000547317 0.000167332"/>
                <joint name="joint5" axis="0 1 0" range="-2.62 2.62"/>
                <geom class="visual" mesh="L5" material="dark"/> 

                <!-- LINK 6 -->
                <body name="link06" pos="0 -0.0755 -0.02" quat="0 1 0 0">
                  <inertial pos="0.0241569 -0.00017355 -0.00143876" quat="0.998779 0.0457735 -0.00663717 0.0173548"
                    mass="0.288758" diaginertia="0.00018333 0.000147464 0.000146786"/>
                  <joint name="joint6" axis="0 0 1" range="-2.62 2.62"/>
                  <geom class="visual" mesh="L6" material="claro"/>                 

                <!-- Gripper fixed-->
                <body name="gripper" pos="0 0 0.005">
                <geom class="visual" mesh="gripper" material="dark"/>
                <site name="attachment_site" size="0.01" pos="0 0 0.1" quat="-1 1 1 1" rgba="1 0 0 1" group="1"/>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body> 
      </body>
    </body>
  </worldbody>

  <actuator>
    <general class="brazito" name="motor1" joint="joint1" ctrlrange="-2.62 2.62" forcerange="-15 15"/>
    <general class="brazito" name="motor2" joint="joint2" ctrlrange="-0.7 4" forcerange="-54 54" gainprm="1500"
      biasprm="0 -1500 -150"/>
    <general class="brazito" name="motor3" joint="joint3" ctrlrange="-2.62 2.62" forcerange="-24 24" />
    <general class="brazito" name="motor4" joint="joint4" ctrlrange="-2.62 2.62" forcerange="-4 4"/>
    <general class="brazito" name="motor5" joint="joint5" ctrlrange="-2.62 2.62" forcerange="-5 5"/>
    <general class="brazito" name="motor6" joint="joint6" ctrlrange="-2.62 2.62" forcerange="-4 4"/>
  </actuator>

  <keyframe>
    <key name="home" qpos="0 1.58 1.07 1.62 -2.04 0" ctrl="0 1.58 1.07 1.62 -2.04 0"/>
    <key name="up" qpos="0 0 0 0 0 0" ctrl="0 0 0 0 0 0"/>
    <key name = "pick" qpos="0.4978 2.35961 -0.0242714 1.61975 2.62017 2.55423e-06"  ctrl="0.4978 2.355 -0.0262 1.62 2.62 0"/>
  </keyframe>
</mujoco>